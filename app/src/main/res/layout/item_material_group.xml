<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- 左侧子项容器（垂直排列每个材料2） -->
    <LinearLayout
        android:id="@+id/sub_items_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_line_eq"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- 引导线：定义 "=" 符号的起始位置 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_line_eq"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="200dp"/>

    <!-- "=" 符号列 -->
    <TextView
        android:id="@+id/equal_sign"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:text="="
        android:textSize="16sp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="@id/guide_line_eq"
        app:layout_constraintEnd_toStartOf="@id/target_text"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- 目标名字（产物） -->
    <TextView
        android:id="@+id/target_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@id/equal_sign"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>